# Git ignore rules for streaming-backend
# =============================================================

# ─── NEVER COMMIT STREAM KEYS ────────────────────────────────
# Allow the keys/ directory itself, but block actual key files
!keys/
keys/*.env
*.env
# Explicitly allow the safe example template (contains no real keys)
!keys/stream_keys.env.example

# ─── Log files (can grow large, generated at runtime) ────────
logs/
*.log

# ─── OS junk ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor temporary files ──────────────────────────────────
*.swp
*.swo
*~
.vscode/
.idea/

# ─── Pre-event report files (generated by pre_event_test.sh) ─
logs/pre_event_report_*.txt

# ─── Nginx runtime files (if any end up here) ────────────────
*.pid
