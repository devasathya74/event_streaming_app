# =============================================================================
# stream_keys.env.example — Template for Stream Keys Configuration
# =============================================================================
# Copy this file to keys/stream_keys.env and fill in your real keys.
#
#   cp keys/stream_keys.env.example keys/stream_keys.env
#   sudo chmod 600 keys/stream_keys.env
#   sudo nano keys/stream_keys.env
#
# ⚠ SECURITY RULES:
#   1. NEVER commit stream_keys.env to git (it's in .gitignore)
#   2. chmod 600 — root read-only
#   3. Rotate keys after EVERY event
#   4. Do not share with vendors, clients, or on-site technicians
# =============================================================================

# ── YouTube ──────────────────────────────────────────────────────────────────
# Get from: YouTube Studio → Go Live → Stream → Stream Key
# Format:   xxxx-xxxx-xxxx-xxxx-xxxx (20 chars, dash-separated)
YT_STREAM_KEY="YOUR_YOUTUBE_STREAM_KEY_HERE"

# ── Facebook ─────────────────────────────────────────────────────────────────
# Get from: Facebook → Professional Dashboard → Live Video → Use Stream Key
# Format:   FB-XXXXXXXXX-0-AbXXXXXXXXXXXXXXXXXXXX
FB_STREAM_KEY="YOUR_FACEBOOK_STREAM_KEY_HERE"

# ── Facebook RTMPS Ingest URL ─────────────────────────────────────────────────
# Do not change unless Facebook officially updates their ingest endpoint.
# Verified as of 2024: live-api-s.facebook.com:443
FB_RTMPS_URL="rtmps://live-api-s.facebook.com:443/rtmp"
